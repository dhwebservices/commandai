{
  "name": "comandr-desktop",
  "version": "1.0.0",
  "description": "Comandr Desktop Agent - AI-powered system automation",
  "main": "dist/main.js",
  "author": "Comandr",
  "license": "MIT",
  "scripts": {
    "dev": "electron .",
    "build": "tsc && electron-builder",
    "build:mac": "tsc && electron-builder --mac",
    "build:win": "tsc && electron-builder --win",
    "build:linux": "tsc && electron-builder --linux",
    "package": "electron-builder --mac --win --linux"
  },
  "build": {
    "appId": "com.comandr.desktop",
    "productName": "Comandr",
    "asar": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "src/**/*.html",
      "src/**/*.js",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "@comandr/desktop-agent": "workspace:*",
    "auto-launch": "^5.0.6",
    "node-notifier": "^10.0.1",
    "robotjs": "^0.7.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^43.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0"
  }
}
