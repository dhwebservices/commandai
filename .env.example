# Copy to .env.local for local dev. Never commit real secrets.

NODE_ENV=local
LOG_LEVEL=debug

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=commandai
POSTGRES_USER=commandai
POSTGRES_PASSWORD=commandai_local

REDIS_URL=redis://localhost:6379

NATS_URL=nats://localhost:4222

API_GATEWAY_PORT=3000
ORCHESTRATOR_PORT=8000

# ADR-009: Supabase is the real DB + auth provider.
SUPABASE_URL=https://xnmmwqrezspgjspdllzb.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-or-publishable-key
# Service role key: NEVER commit the real value. Get it from
# Supabase dashboard > Project Settings > API > service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# ADR-009: Resend sends all transactional auth email.
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL=CommandAI <auth@dhwebsiteservices.co.uk>

# ADR-010: agent-gateway (gRPC AgentChannel) — NOT production-cleared, see Security.md
AGENT_GATEWAY_PORT=50051
# Leave unset in any real environment. Local dev only.
AGENT_GATEWAY_ALLOW_INSECURE=true
TLS_CERT_PATH=
TLS_KEY_PATH=
TLS_CA_CERT_PATH=
